# =============================================================================
# AdoraTrip — Root .gitignore
# Covers: Django, Next.js, Docker, Python, Node, TypeScript, VS Code, macOS
# =============================================================================

# =============================================================================
# SECRETS — never commit
# =============================================================================
.env
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key
*.crt
*.p12
secrets/
credentials.json

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.env.bak/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# =============================================================================
# DJANGO
# =============================================================================
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Collected static files (generated by collectstatic)
Backend/staticfiles/
Backend/mediafiles/

# Django migrations (keep these — they are source of truth)
# !Backend/*/migrations/*.py

# =============================================================================
# NODE / JAVASCRIPT / TYPESCRIPT
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
.npm/
.yarn/

# =============================================================================
# NEXT.JS
# =============================================================================
Frontend/.next/
Frontend/out/
Frontend/.vercel/

FrontendUISample/.next/
FrontendUISample/out/
FrontendUISample/.vercel/

# Next.js cache (can be regenerated)
.next/

# =============================================================================
# DOCKER
# =============================================================================
# Never commit SSL certs into the repo
docker/nginx/ssl/
Backend/docker/nginx/ssl/

# =============================================================================
# TESTING & COVERAGE
# =============================================================================
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# JavaScript test output
coverage/
.nyc_output/

# =============================================================================
# IDE / EDITORS
# =============================================================================
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (PyCharm, WebStorm)
.idea/
*.iml
*.iws
*.ipr
out/

# Vim/Neovim
*.swp
*.swo
*.swn
*~
.netrwhist

# Emacs
*#
.#*
\#*#

# Sublime Text
*.sublime-project
*.sublime-workspace

# =============================================================================
# OPERATING SYSTEM
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
npm-debug.log*
pids/
*.pid
*.seed
*.pid.lock

# =============================================================================
# MISC
# =============================================================================
*.bak
*.tmp
*.orig
*.patch
.sass-cache/
connect.lock
libpeerconnection.log
testem.log
typings/

# Claude Code session files (not project-specific)
.claude/
.github/
