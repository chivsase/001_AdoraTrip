# ============================================================
# AdoraTour — Environment Variables Example
# Copy this to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# Django
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=adoratour_db
POSTGRES_USER=adoratour_user
POSTGRES_PASSWORD=adoratour_pass

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=adoratour-media
AWS_S3_REGION_NAME=ap-southeast-1

# Stripe
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# SendGrid
SENDGRID_API_KEY=SG.xxx
DEFAULT_FROM_EMAIL=noreply@adoratour.com

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_NUMBER=+1234567890

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Sentry (production)
SENTRY_DSN=

# Django superuser (created on first startup)
DJANGO_SUPERUSER_EMAIL=admin@adoratour.com
DJANGO_SUPERUSER_PASSWORD=admin123

# Flower (Celery monitoring)
FLOWER_USER=admin
FLOWER_PASSWORD=admin123

# pgAdmin
PGADMIN_EMAIL=admin@adoratour.com
PGADMIN_PASSWORD=admin123
