# =============================================================================
# AdoraTrip — Root Environment Variables Template
# Copy to .env and fill in real values before running docker compose.
#
#   cp .env.example .env
#
# NEVER commit .env to git. It is listed in .gitignore.
# =============================================================================

# =============================================================================
# DATABASE — PostgreSQL 16
# =============================================================================
POSTGRES_DB=adoratrip_db
POSTGRES_USER=adoratrip_user
POSTGRES_PASSWORD=change-me-in-production

# =============================================================================
# DJANGO BACKEND
# =============================================================================

# Generate a new secret key for production:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-change-this-in-production

# Set to False in production
DEBUG=True

# Comma-separated list of allowed host headers
ALLOWED_HOSTS=localhost,127.0.0.1,adoratrip.com,www.adoratrip.com

# Django settings module — overridden per-service in docker-compose
DJANGO_SETTINGS_MODULE=config.settings.development

# Automatically created on first container start (entrypoint.sh)
DJANGO_SUPERUSER_EMAIL=admin@adoratrip.com
DJANGO_SUPERUSER_PASSWORD=change-me-in-production

# =============================================================================
# REDIS — Cache + Celery Broker + Channels Layer
# =============================================================================
REDIS_URL=redis://redis:6379/0
# Set a strong password in production (matches redis requirepass in prod compose)
REDIS_PASSWORD=

# =============================================================================
# CORS — allowed origins for the Django API
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://adoratrip.com

# =============================================================================
# NEXT.JS FRONTEND
# =============================================================================

# Public URL of the API (reachable from the browser)
# In production: https://adoratrip.com/api
NEXT_PUBLIC_API_URL=http://localhost/api

# Public WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost/ws

# Next.js base path (leave empty unless serving under a sub-path)
BASEPATH=

# Public-facing app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# AWS S3 — Media storage (optional in development; required in production)
# =============================================================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=adoratrip-media
AWS_S3_REGION_NAME=ap-southeast-1
# Optional: CloudFront CDN domain for media assets
AWS_S3_CUSTOM_DOMAIN=

# =============================================================================
# STRIPE — Payments
# =============================================================================
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# =============================================================================
# SENDGRID — Transactional email
# =============================================================================
SENDGRID_API_KEY=SG.your_key_here
DEFAULT_FROM_EMAIL=noreply@adoratrip.com

# =============================================================================
# TWILIO — SMS notifications
# =============================================================================
TWILIO_ACCOUNT_SID=ACyour_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

# =============================================================================
# GOOGLE OAuth — Social Login
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# FACEBOOK OAuth — Social Login
# =============================================================================
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# =============================================================================
# SENTRY — Error tracking (leave empty to disable)
# =============================================================================
SENTRY_DSN=

# =============================================================================
# DEV TOOLS (only active when --profile tools is passed)
# =============================================================================

# Celery Flower task monitor — http://localhost:5555
FLOWER_USER=admin
FLOWER_PASSWORD=admin123

# pgAdmin — http://localhost:5050
PGADMIN_EMAIL=admin@adoratrip.com
PGADMIN_PASSWORD=admin123
