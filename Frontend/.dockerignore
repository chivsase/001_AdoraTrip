# =============================================================================
# AdoraTrip Frontend — .dockerignore
# Prevents large/sensitive local paths from entering the Docker build context.
# Especially critical for node_modules (~500 MB) and .next (~200 MB).
# =============================================================================

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Next.js build output ---
# Rebuilt from source inside the container
.next/
out/

# --- Environment files — NEVER bake secrets into an image ---
.env
.env.*
!.env.example

# --- Git ---
.git/
.gitignore
.gitattributes

# --- Docker files (not needed inside the image) ---
Dockerfile*
docker-compose*.yml

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
.editorconfig

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Test artifacts ---
coverage/
.nyc_output/

# --- Documentation ---
*.md
docs/

# --- CI/CD ---
.github/
.gitlab-ci.yml
.circleci/

# --- Misc ---
*.bak
*.tmp
*.orig
